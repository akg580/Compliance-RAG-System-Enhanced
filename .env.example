# API Keys (for production backend integration)
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here
REACT_APP_PINECONE_API_KEY=your_pinecone_api_key_here
REACT_APP_PINECONE_ENVIRONMENT=your_pinecone_environment
#REACT_APP_API_URL=https://unfine-unmutually-zechariah.ngrok-free.dev
VITE_API_URL=http://localhost:8000

# System Configuration
REACT_APP_CONFIDENCE_THRESHOLD=0.75
REACT_APP_MAX_CHUNKS_RETRIEVED=3
REACT_APP_API_TIMEOUT=5000

# Feature Flags
REACT_APP_ENABLE_AUDIT_LOGGING=true
REACT_APP_ENABLE_RBAC=true
REACT_APP_ENABLE_VERSION_TRACKING=true

# Development
REACT_APP_ENV=development
REACT_APP_DEBUG_MODE=false