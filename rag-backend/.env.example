# RAG Backend - Environment Variables
# Copy to .env and adjust as needed.

# Server
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api

# ChromaDB (persistent store path)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=policy_chunks

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG settings
RAG_TOP_K=5
RAG_MIN_SCORE=0.5

# CORS - frontend origin (React dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: OpenAI for optional LLM summarization (leave empty to use retrieval-only)
# OPENAI_API_KEY=
