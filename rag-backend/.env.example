# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
# Place this file at:  rag-backend/.env

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Groq (free & fast) — get key at https://console.groq.com
GROQ_API_KEY=your_key_here

# CORS — set to your frontend URL (Vite default is 5173)
#ALLOWED_ORIGINS=http://localhost:5173

# ComplianceAI — Backend .env


# JWT secret — run: python3 -c "import secrets; print(secrets.token_hex(32))"
# If missing, a random secret is generated each restart (tokens invalidated on redeploy)
JWT_SECRET=your jwt secret here (64 char hex)

# ── CORS (comma-separated, no trailing slash) ─────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://your-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Token lifetimes ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── RAG tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=150
CHUNK_OVERLAP=30
TOP_K_RESULTS=5
